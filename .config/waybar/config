{
  "layer": "top",
  "position": "top",
  "height": 36,
  "spacing": 0,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "battery", "network", "pulseaudio", "tray"],

  "hyprland/workspaces": {
    "format": "{id}",
