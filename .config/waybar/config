{
  "layer": "top",
  "position": "top",
  "height": 36,
  "spacing": 0,
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "battery",
    "network",
    "pulseaudio",
    "backlight",
    "tray",
    "custom/power"
  ],
  "hyprland/workspaces": {
    "format": "{id}",
    "on-click": "activate"
  },
  "clock": {
    "format": " {:%H:%M}",
    "format-alt": " {:%A, %d %B %Y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "cpu": {
    "interval": 2,
    "format": " 󰻠 {usage}%",
    "on-click": "kitty --class htop-float -e htop",
    "tooltip": false
  },
  "memory": {
    "interval": 5,
    "format": " 󰍛 {used:0.1f}G",
    "on-click": "kitty --class htop-float -e htop",
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G"
  },
  "backlight": {
    "format": " {icon} {percent}%",
    "format-icons": [
      "󰃞",
      "󰃟",
      "󰃠"
    ],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-"
  },
  "battery": {
    "interval": 30,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": " {icon} {capacity}%",
    "format-charging": " 󰂄 {capacity}%",
    "format-plugged": " 󰚥 {capacity}%",
    "format-icons": [
      "󰁺",
      "󰁻",
      "󰁼",
      "󰁽",
      "󰁾",
      "󰁿",
      "󰂀",
      "󰂁",
      "󰂂",
      "󰁹"
    ]
  },
  "network": {
    "interval": 5,
    "format-wifi": " 󰤨 {signalStrength}%",
    "format-ethernet": " 󰈀 {ifname}",
    "format-disconnected": " 󰤭 off",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n󰕒 {bandwidthUpBits}  󰇚 {bandwidthDownBits}",
    "on-click": "nm-connection-editor"
  },
  "pulseaudio": {
    "format": " {icon} {volume}%",
    "format-muted": " 󰝟 muted",
    "format-icons": {
      "default": [
        "󰕿",
        "󰖀",
        "󰕾"
      ]
    },
    "on-click": "pavucontrol",
    "tooltip": false
  },
  "tray": {
    "spacing": 8
  },
  "custom/power": {
    "format": "⏻",
    "tooltip": false,
    "on-click": "wlogout --protocol layer-shell -b 3 -T 350 -B 350 -L 350 -R 350"
    // "on-click": "wlogout"
  }
}
